{
  "name": "horus-engine",
  "productName": "Horus Engine",
  "version": "1.4.1",
  "description": "HORUS ENGINE: God-Tier PC Automation",
  "author": "Gerar",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.horus.engine",
    "copyright": "Copyright 2026 Gerar",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "extraResources": [
      {
        "from": "mis_scripts",
        "to": "mis_scripts",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
