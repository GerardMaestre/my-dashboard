{
  "name": "horus-engine",
  "productName": "Horus Engine",
  "version": "1.4.1",
  "description": "HORUS ENGINE: God-Tier PC Automation",
  "author": "Gerar",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "clean:dist": "node -e \"const fs=require('fs');const p=require('path').resolve('..','dist');if(fs.existsSync(p)){fs.rmSync(p,{recursive:true,force:true});console.log('cleaned',p);}else{console.log('dist not found',p);}\"",
    "verify:build": "node scripts/verify-build-prereqs.js",
    "verify:build:strict": "node scripts/verify-build-prereqs.js --strict",
    "build": "npm run verify:build && electron-builder",
    "build:strict": "npm run verify:build:strict && electron-builder",
    "build:portable": "npm run verify:build && electron-builder --win portable",
    "build:portable:strict": "npm run verify:build:strict && electron-builder --win portable",
    "build:mft": "cargo build --manifest-path native_modules/mft_reader/Cargo.toml --release",
    "run:mft:test": "native_modules\\mft_reader\\target\\release\\mft_reader.exe scan --root C:\\ --format json",
    "release": "npm run clean:dist && npm run build:mft && npm run build:strict",
    "release:portable": "npm run clean:dist && npm run build:mft && npm run build:portable:strict"
  },
  "build": {
    "appId": "com.horus.engine",
    "copyright": "Copyright 2026 Gerar",
    "asar": true,
    "compression": "maximum",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": [
        "nsis",
        "zip",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "HorusEngine-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "HorusEngine-Setup-${version}-${os}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "HorusEngine-Portable-${version}-${os}-${arch}.${ext}"
    },
    "extraResources": [
      {
        "from": "mis_scripts",
        "to": "mis_scripts",
        "filter": [
          "**/*",
          "!env_python",
          "!env_python/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/ffmpeg.exe",
          "!**/yt-dlp.exe",
          "!tools/wiztree.zip",
          "!tools/WizTree*.exe",
          "!tools/locale/**"
        ]
      },
      {
        "from": "native_modules",
        "to": "native_modules",
        "filter": [
          "mft_reader/target/release/mft_reader.exe"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "systeminformation": "^5.31.5"
  }
}
