<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nexus Executor Pro</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <!-- BARRA SUPERIOR ESTILO MACOS -->
    <div class="mac-titlebar">
        <div class="mac-traffic-lights">
            <button class="mac-btn close" onclick="windowControl('close')" title="Cerrar"></button>
            <button class="mac-btn minimize" onclick="windowControl('minimize')" title="Minimizar"></button>
            <button class="mac-btn maximize" onclick="windowControl('maximize')" title="Maximizar"></button>
        </div>
        <div class="mac-title">Nexus Executor Pro</div>
    </div>

    <!-- PANTALLA DE CARGA INICIAL -->
    <div id="splash-screen" class="splash-screen">
        <div class="splash-content">
            <svg class="splash-spinner" viewBox="0 0 50 50">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
            </svg>
            <div class="splash-text">Iniciando Motor Nexus...</div>
        </div>
    </div>

    <!-- FONDO FLUIDO ESTILO APPLE -->
    <div class="mac-wallpaper"></div>

    <div class="layout">
        <!-- BARRA LATERAL -->
        <aside class="sidebar mac-glass">
            <div class="sidebar-header">
                <input type="text" id="search-input" class="mac-input" placeholder="Buscar automatización...">
                <button id="btn-refresh" class="mac-icon-btn" title="Recargar Scripts">
                    <svg viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                </button>
            </div>
            <ul id="script-list" class="script-list">
                <!-- Tarjetas inyectadas por JS -->
            </ul>
        </aside>

        <!-- PANEL PRINCIPAL (CONSOLA) -->
        <main class="console-container">
            <div class="toolbar mac-glass">
                <div class="tool-group">
                    <label>Motor:</label>
                    <select id="run-mode" class="mac-input">
                        <option value="internal">Silencioso (Integrado)</option>
                        <option value="external">Nativo (CMD/Terminal)</option>
                    </select>
                </div>
                <div class="tool-group flex-1">
                    <label>Parámetros:</label>
                    <input type="text" id="script-args" class="mac-input w-full" placeholder="Añade rutas, contraseñas o argumentos aquí...">
                </div>
                <button id="btn-clear" class="mac-btn-outline">Limpiar Log</button>
            </div>
            
            <div class="terminal-wrapper">
                <div id="terminal" class="mac-terminal mac-glass">
                    <span class="log-system"> Sistema Nexus inicializado. Listo para operar.</span>
                </div>
            </div>
        </main>
    </div>

    <!-- MODAL AUTOPILOT -->
    <div id="autopilot-modal" class="modal-overlay">
        <div class="mac-modal mac-glass">
            <h3>Configurar Autopilot</h3>
            <p id="sch-filename" class="modal-subtitle">script.py</p>
            
            <div class="mac-form-group">
                <label>Ejecutar en bucle cada:</label>
                <div style="display: flex; gap: 10px;">
                    <input type="number" id="sch-time" class="mac-input" value="15" min="1" style="width: 80px;">
                    <select id="sch-unit" class="mac-input" style="flex: 1;">
                        <option value="1000">Segundos</option>
                        <option value="60000" selected>Minutos</option>
                        <option value="3600000">Horas</option>
                    </select>
                </div>
            </div>
            
            <div class="mac-modal-actions">
                <button class="mac-btn-outline" onclick="cerrarAutopilot()">Cancelar</button>
                <button class="mac-btn-primary" onclick="iniciarAutopilot()">Iniciar Bucle</button>
            </div>
        </div>
    </div>

    <script src="renderer.js"></script>
</body>
</html>